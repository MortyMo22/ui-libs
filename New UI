-- ============================================================================
-- SYSTEM 5: CLEANUP / CONNECTION REGISTRY (must be first, used everywhere)
-- ============================================================================
local Cleanup = {}
Cleanup.__index = Cleanup

function Cleanup.new()
    return setmetatable({ _connections = {}, _tweens = {} }, Cleanup)
end

function Cleanup:Add(connection)
    if connection and connection.Connected ~= nil then
        table.insert(self._connections, connection)
    end
    return connection
end

function Cleanup:Track(tween)
    if tween then table.insert(self._tweens, tween) end
    return tween
end

function Cleanup:Destroy()
    for _, c in ipairs(self._connections) do
        if c and c.Connected then c:Disconnect() end
    end
    for _, t in ipairs(self._tweens) do
        if t then pcall(function() t:Cancel(); t:Destroy() end) end
    end
    self._connections = {}
    self._tweens = {}
end

-- Global registry for the whole lib
local _globalCleanup = Cleanup.new()

-- ============================================================================
-- SYSTEM 1: SCALE MANAGER
-- ============================================================================
local Scale = {}
local Metrics = {}

do
    local BASE_W, BASE_H = 1280, 720
    local MIN_SCALE, MAX_SCALE = 0.55, 1.6

    -- Reference metrics at 1× scale
    Metrics.ControlHeight   = 34
    Metrics.SmallControl    = 28
    Metrics.LargeControl    = 44
    Metrics.FontBase        = 14
    Metrics.FontTitle       = 16
    Metrics.FontSmall       = 12
    Metrics.Padding         = 8
    Metrics.PaddingLarge    = 10
    Metrics.Radius          = 8
    Metrics.RadiusLarge     = 12
    Metrics.Spacing         = 6
    Metrics.StrokeThick     = 1
    Metrics.SliderHeight    = 18
    Metrics.WindowMinW      = 420
    Metrics.WindowMinH      = 320

    Scale.factor = 1.0

    local function computeFactor()
        local Camera = workspace.CurrentCamera
        local vp = (Camera and Camera.ViewportSize) or Vector2.new(BASE_W, BASE_H)
        local sw, sh = vp.X, vp.Y
        local isMob = UIS.TouchEnabled and not UIS.KeyboardEnabled

        if isMob then
            -- Mobile/tablet: scale down if screen is small, slight boost for thumb targets
            local ref = math.min(sw / BASE_W, sh / BASE_H)
            Scale.factor = math.clamp(ref * 1.1, MIN_SCALE, 1.0)
        else
            -- Desktop/PC: always exactly 1.0 — no scaling applied
            -- Scale system is still available for mobile code paths, but
            -- desktop must look identical to the original v2.0 layout.
            Scale.factor = 1.0
        end
    end

    computeFactor()

    -- Re-compute on viewport change
    local Camera = workspace.CurrentCamera
    if Camera then
        _globalCleanup:Add(Camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
            computeFactor()
        end))
    end

    -- Convenience: scale a pixel value
    function Scale.px(value)
        return math.round(value * Scale.factor)
    end

    -- Convenience: scaled metric
    function Scale.m(key)
        local base = Metrics[key]
        if not base then return 0 end
        return Scale.px(base)
    end
end

-- ============================================================================
-- SYSTEM 4: ANIMATION MODULE
-- ============================================================================
local Anim = {}
do
    local function info(t, style, dir)
        return TweenInfo.new(t, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out)
    end

    Anim.Fast   = info(0.12)
    Anim.Normal = info(0.22)
    Anim.Slow   = info(0.35)
    Anim.Spring = info(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    Anim.Ease   = info(0.25, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)

    -- Play a tween; returns the tween so callers can track/cancel
    function Anim:Play(instance, tweenInfo, goals)
        local t = TweenService:Create(instance, tweenInfo, goals)
        t:Play()
        return t
    end

    -- Cancel-safe: cancel existing stored tween then play new one
    function Anim:Replace(stored, instance, tweenInfo, goals)
        if stored and stored.PlaybackState == Enum.PlaybackState.Playing then
            stored:Cancel()
        end
        return self:Play(instance, tweenInfo, goals)
    end

    -- Hover helper: tracked connections for use with the cleanup registry
    function Anim:Hover(btn, normalColor, hoverColor, registry)
        local reg = registry or _globalCleanup
        local c1 = reg:Add(btn.MouseEnter:Connect(function()
            Anim:Play(btn, Anim.Fast, { BackgroundColor3 = hoverColor })
        end))
        local c2 = reg:Add(btn.MouseLeave:Connect(function()
            Anim:Play(btn, Anim.Fast, { BackgroundColor3 = normalColor })
        end))
        return { c1, c2 }
    end
end

-- ============================================================================
-- KEYBIND SYSTEM (unchanged, but connections tracked)
-- ============================================================================
local keybinds = {}
local currentBindRecorder

local function addKeybind(key, fn)
    if not key then return end
    local list = keybinds[key]
    if not list then list = {}; keybinds[key] = list end
    table.insert(list, fn)
end

local function removeKeybind(key, fn)
    if not key then return end
    local list = keybinds[key]
    if not list then return end
    for i = #list, 1, -1 do
        if list[i] == fn then table.remove(list, i) end
    end
    if list and #list == 0 then keybinds[key] = nil end
end

_globalCleanup:Add(UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if currentBindRecorder and input.UserInputType == Enum.UserInputType.Keyboard then
        currentBindRecorder(input.KeyCode)
        currentBindRecorder = nil
        return
    end
    local list = keybinds[input.KeyCode]
    if list then
        for _, fn in ipairs(list) do fn() end
    end
end))

