            -- SYSTEM 3: TEXTBOX FIX + INPUT IMPROVEMENTS
            -- ================================================================
            --[[
                TextBox:
                - Fixed: Text="" (was "TextBox"), PlaceholderText used properly
                - Added: focus accent stroke, hover state, blur stroke-reset
                - Added optional: MaxLength, NumbersOnly, FloatOnly, OnChanged, OnSubmitted
                - Backward compatible (old API: TextBox(placeholder, callback) still works)
            ]]
            function sectionAPI:TextBox(placeholder, callback, opts)
                opts = opts or {}
                local box = create("TextBox", {
                    Size=UDim2.new(1,0,0,34),
                    BackgroundColor3=Theme.control,
                    TextColor3=Theme.text, Font=FONT, TextSize=14,
                    PlaceholderText=placeholder or "",
                    PlaceholderColor3=Theme.textDim,
                    Text="",                          -- FIX: was missing / wrong
                    ClearTextOnFocus=false,
                }, {})
                addCorner(box, 8)
                local stroke = addStroke(box, Theme.stroke, 1, 0.5)
                box.Parent=stack

                -- Focus animation: accent stroke
                box.Focused:Connect(function()
                    Anim:Play(stroke, Anim.Fast, { Color = Theme.accent, Transparency = 0 })
                end)
                box.FocusLost:Connect(function(enterPressed)
                    Anim:Play(stroke, Anim.Fast, { Color = Theme.stroke, Transparency = 0.5 })
                    if callback then callback(box.Text, enterPressed) end
                    if opts.OnSubmitted and enterPressed then opts.OnSubmitted(box.Text) end
                end)

                -- OnChanged
                if opts.OnChanged then
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        opts.OnChanged(box.Text)
                    end)
                end

                -- MaxLength filter
                if opts.MaxLength then
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        if #box.Text > opts.MaxLength then
                            box.Text = box.Text:sub(1, opts.MaxLength)
                        end
                    end)
                end

                -- NumbersOnly filter
                if opts.NumbersOnly then
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        local clean = box.Text:gsub("[^%d]", "")
                        if clean ~= box.Text then box.Text = clean end
                    end)
                end

                -- FloatOnly filter
                if opts.FloatOnly then
                    box:GetPropertyChangedSignal("Text"):Connect(function()
                        local clean = box.Text:gsub("[^%d%.]", "")
                        if clean ~= box.Text then box.Text = clean end
                    end)
                end

                return box
            end

