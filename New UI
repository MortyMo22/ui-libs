                local function setState(val)
                    state=val; box.BackgroundColor3=state and Theme.accent or Theme.control
                    if onToggle then onToggle(state,bindKey) end
                end
                box.MouseButton1Click:Connect(function() setState(not state) end)

                local function onBind()
                    setState(not state)
                    if onTrigger then onTrigger(state,bindKey) end
                end
                local function updateBind(newKey)
                    removeKeybind(bindKey,onBind); bindKey=newKey
                    keyBtn.Text=bindKey.Name; keyBtn.BackgroundColor3=Theme.control
                    addKeybind(bindKey,onBind)
                end
                keyBtn.MouseButton1Click:Connect(function()
                    keyBtn.Text="Press key..."; keyBtn.BackgroundColor3=Theme.accentDim
                    currentBindRecorder=function(newKey) updateBind(newKey) end
                end)
                updateBind(bindKey)

                return { Set=setState, Get=function() return state end,
                    SetBind=function(newKey) updateBind(newKey) end }
            end

            function sectionAPI:ToggleBind(text, opts)
                local bindKey = (opts and opts.Bind) or Enum.KeyCode.R
