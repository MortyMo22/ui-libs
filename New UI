                if label and label ~= "" then
                    create("TextLabel", {
                        Size=UDim2.new(1,0,0,18), BackgroundTransparency=1,
                        Text=label, TextColor3=Theme.textDim, Font=FONT, TextSize=12+1,
                        TextXAlignment=Enum.TextXAlignment.Left, Parent=wrapper,
                    }, {})
                    yOffset = 22
                    wrapper.Size = UDim2.new(1, 0, 0, height + yOffset)
                end

                local scroll = create("ScrollingFrame", {
                    Size=UDim2.new(1,0,0,height), Position=UDim2.new(0,0,0,yOffset),
                    BackgroundColor3=Theme.panel, ScrollBarThickness=5,
                    ScrollBarImageColor3=Theme.stroke,
                    AutomaticCanvasSize=Enum.AutomaticSize.Y,
                    CanvasSize=UDim2.new(0,0,0,0), BorderSizePixel=0,
                    ClipsDescendants=true,
                }, {})
                scroll.Parent = wrapper
                addCorner(scroll, 8); addStroke(scroll, Theme.stroke, 1, 0.5)

                local innerLayout = Instance.new("UIListLayout")
                innerLayout.FillDirection = Enum.FillDirection.Vertical
                innerLayout.Padding = UDim.new(0, padding2)
                innerLayout.SortOrder = Enum.SortOrder.LayoutOrder
                innerLayout.Parent = scroll

                local innerPad = Instance.new("UIPadding")
                innerPad.PaddingTop=UDim.new(0,4); innerPad.PaddingBottom=UDim.new(0,4)
                innerPad.PaddingLeft=UDim.new(0,4); innerPad.PaddingRight=UDim.new(0,4)
                innerPad.Parent = scroll

                local listObj = {}

                function listObj:Clear()
                    for _, child in ipairs(scroll:GetChildren()) do
                        if child:IsA("Frame") or child:IsA("TextButton") then child:Destroy() end
                    end
                end

                function listObj:AddItem(frame)
                    frame.Parent = scroll
                end

                function listObj:SetPadding(px)
                    innerLayout.Padding = UDim.new(0, px)
                end

                function listObj:SetHeight(px)
                    scroll.Size = UDim2.new(1, 0, 0, px)
                    wrapper.Size = UDim2.new(1, 0, 0, px + yOffset)
                end

                function listObj:SetMaxHeight(px)
                    if scroll.AbsoluteSize.Y > px then
                        scroll.Size=UDim2.new(1,0,0,px)
                        wrapper.Size=UDim2.new(1,0,0,px+yOffset)
                    end
                end

                function listObj:GetFrame() return scroll end

                function listObj:Card(cardOpts)
                    cardOpts = cardOpts or {}
                    local cardFrame = create("Frame", {
                        Size = UDim2.new(1, -8, 0, 10),
                        BackgroundColor3 = Theme.panel2, BorderSizePixel=0,
                        AutomaticSize = Enum.AutomaticSize.Y,
                    }, {})
                    cardFrame.Parent = scroll
                    addCorner(cardFrame, 8); addStroke(cardFrame, Theme.stroke, 1, 0.4)

                    local cp = Instance.new("UIPadding")
                    cp.PaddingTop=UDim.new(0,8); cp.PaddingBottom=UDim.new(0,8)
                    cp.PaddingLeft=UDim.new(0,8); cp.PaddingRight=UDim.new(0,8)
                    cp.Parent = cardFrame

                    local cs = create("Frame", {
                        Size=UDim2.new(1,0,0,0), BackgroundTransparency=1,
                        AutomaticSize=Enum.AutomaticSize.Y,
                    }, {})
                    cs.Parent = cardFrame

                    local cl = Instance.new("UIListLayout")
                    cl.FillDirection=Enum.FillDirection.Vertical
                    cl.Padding=UDim.new(0,4); cl.Parent=cs

                    return makeCardAPI(cardFrame, cs)
                end

                return listObj
            end

