                        CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
                    }, {})
                    inner.Parent = outer
                else
                    inner = create("Frame", { Size=UDim2.fromScale(1,1), BackgroundTransparency=1 }, {})
                    inner.Parent = outer
                end

                local containerObj = {}
                function containerObj:Mount(instance) instance.Parent = inner end
