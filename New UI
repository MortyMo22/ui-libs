                            ov:Destroy(); pop:Destroy(); openPopup=nil
                        end)
                    end
                    ov.MouseButton1Click:Connect(function() ov:Destroy(); pop:Destroy(); openPopup=nil end)
                    openPopup=pop
                end

                btn.MouseButton1Click:Connect(function()
                    if openPopup then openPopup:Destroy(); openPopup=nil else open() end
                end)

                return {
                    Get=function() return current end,
                    Set=function(val)
                        if table.find(options,val) then
