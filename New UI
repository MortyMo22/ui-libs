-- SYSTEM 2: NOTIFICATION SYSTEM
-- Standalone – coexists with existing minimize hint
-- ============================================================================
local NotifSystem = {}
do
    local MAX_NOTIFS = 5
    local NOTIF_W    = 280
    local NOTIF_H    = 70
    local NOTIF_GAP  = 8
    local EDGE_PAD   = 16

    local activeNotifs = {}   -- ordered list of active notif frames
    local queue        = {}   -- pending notifs when at max

    local notifGui     = nil  -- created lazily on first call

    local TYPE_COLORS = {
        Success = Theme.notifSuccess,
        Error   = Theme.notifError,
        Warning = Theme.notifWarning,
        Info    = Theme.notifInfo,
    }

    local TYPE_ICONS = {
        Success = "✓",
        Error   = "✕",
        Warning = "⚠",
        Info    = "ℹ",
    }

    local function ensureGui()
        if notifGui and notifGui.Parent then return end
        notifGui = create("ScreenGui", {
            Name = "RoundedUI_Notifs",
            ResetOnSpawn = false,
            IgnoreGuiInset = true,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
            DisplayOrder = 2147483646,
        }, {})
        notifGui.Parent = game:GetService("CoreGui")
    end

    local function repositionAll()
        -- Stack from bottom-right upward
        local Camera = workspace.CurrentCamera
        local vpY = Camera and Camera.ViewportSize.Y or 720
        local vpX = Camera and Camera.ViewportSize.X or 1280
        -- Scale notification width on mobile
        local nw = isMobile() and math.min(NOTIF_W, vpX - EDGE_PAD * 2) or NOTIF_W

        for i, frame in ipairs(activeNotifs) do
            local targetY = vpY - EDGE_PAD - i * (NOTIF_H + NOTIF_GAP)
            local targetX = vpX - nw - EDGE_PAD
            Anim:Play(frame, Anim.Ease, {
                Position = UDim2.new(0, targetX, 0, targetY)
            })
        end
    end

    local function dismissNotif(frame, cleanup)
        -- Slide out to the right, then destroy
        local targetX = frame.AbsolutePosition.X + NOTIF_W + EDGE_PAD + 40
        local t = Anim:Play(frame, Anim.Normal, {
            Position = UDim2.new(0, targetX, 0, frame.AbsolutePosition.Y),
            BackgroundTransparency = 1,
        })
        -- Remove from active list immediately so repositioning is correct
        for i, f in ipairs(activeNotifs) do
            if f == frame then table.remove(activeNotifs, i); break end
        end
        repositionAll()

        task.delay(0.3, function()
            if cleanup then cleanup() end
            if frame and frame.Parent then frame:Destroy() end
            -- Show next queued notif if any
            if #queue > 0 then
                local next = table.remove(queue, 1)
                NotifSystem._show(next)
            end
        end)
    end

    function NotifSystem._show(cfg)
        ensureGui()
        if #activeNotifs >= MAX_NOTIFS then
            table.insert(queue, cfg)
            return
        end

        local title    = cfg.Title    or "Notification"
        local content  = cfg.Content  or ""
        local duration = cfg.Duration or 4
        local ntype    = cfg.Type     or "Info"
        local accentColor = TYPE_COLORS[ntype] or Theme.accent
        local icon        = TYPE_ICONS[ntype]  or "ℹ"

        local Camera = workspace.CurrentCamera
        local vpX = Camera and Camera.ViewportSize.X or 1280
        local vpY = Camera and Camera.ViewportSize.Y or 720
        local nw  = isMobile() and math.min(NOTIF_W, vpX - EDGE_PAD * 2) or NOTIF_W

        -- Start off-screen to the right
        local startX = vpX + 20
        local startY = vpY - EDGE_PAD - (1 + #activeNotifs) * (NOTIF_H + NOTIF_GAP)

        local frame = create("Frame", {
            Size = UDim2.new(0, nw, 0, NOTIF_H),
            Position = UDim2.new(0, startX, 0, startY),
            BackgroundColor3 = Theme.panel2,
            ZIndex = 300,
        }, {})
        frame.Parent = notifGui
        addCorner(frame, 10)
        addStroke(frame, accentColor, 2, 0.3)

        -- Accent strip on the left
        local strip = create("Frame", {
            Size = UDim2.new(0, 4, 1, -16),
            Position = UDim2.new(0, 8, 0, 8),
            BackgroundColor3 = accentColor,
            ZIndex = 301,
        }, {})
        strip.Parent = frame; addCorner(strip, 3)

        -- Icon
        create("TextLabel", {
            Size = UDim2.new(0, 24, 0, 24),
            Position = UDim2.new(0, 20, 0.5, -12),
            BackgroundTransparency = 1,
            Text = icon,
            TextColor3 = accentColor,
            Font = FONT_B,
            TextSize = 16,
            ZIndex = 301,
            Parent = frame,
        }, {})

        -- Title
        create("TextLabel", {
            Size = UDim2.new(1, -60, 0, 20),
            Position = UDim2.new(0, 50, 0, 10),
            BackgroundTransparency = 1,
            Text = title,
            TextColor3 = Theme.text,
            Font = FONT_B,
            TextSize = 13,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 301,
            Parent = frame,
        }, {})

        -- Content
        if content ~= "" then
            create("TextLabel", {
                Size = UDim2.new(1, -60, 0, 26),
                Position = UDim2.new(0, 50, 0, 32),
                BackgroundTransparency = 1,
                Text = content,
                TextColor3 = Theme.textDim,
                Font = FONT,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
                ZIndex = 301,
                Parent = frame,
            }, {})
        end

        -- Progress bar
        local progressBg = create("Frame", {
            Size = UDim2.new(1, -16, 0, 3),
            Position = UDim2.new(0, 8, 1, -7),
            BackgroundColor3 = Theme.control,
            ZIndex = 301,
        }, {})
        progressBg.Parent = frame; addCorner(progressBg, 2)

        local progressFill = create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = accentColor,
            ZIndex = 302,
        }, {})
        progressFill.Parent = progressBg; addCorner(progressFill, 2)

        -- Close button (×)
        local closeX = create("TextButton", {
            Size = UDim2.new(0, 20, 0, 20),
            Position = UDim2.new(1, -24, 0, 6),
            BackgroundTransparency = 1,
            Text = "×",
            TextColor3 = Theme.textDim,
            Font = FONT_B,
            TextSize = 16,
            ZIndex = 302,
        }, {})
        closeX.Parent = frame

        table.insert(activeNotifs, frame)
        repositionAll()

        -- Slide in
        local Camera2 = workspace.CurrentCamera
        local vx2 = Camera2 and Camera2.ViewportSize.X or 1280
        Anim:Play(frame, Anim.Spring, {
            Position = UDim2.new(0, vx2 - nw - EDGE_PAD, 0, frame.Position.Y.Offset),
        })

        local dismissed = false
        local function doClose()
            if dismissed then return end
            dismissed = true
            dismissNotif(frame, nil)
        end

        closeX.MouseButton1Click:Connect(doClose)

        -- Timer countdown
        local elapsed = 0
        local conn
        conn = RunService.Heartbeat:Connect(function(dt)
            if dismissed then conn:Disconnect(); return end
            elapsed = elapsed + dt
            local t2 = math.clamp(1 - (elapsed / duration), 0, 1)
            progressFill.Size = UDim2.new(t2, 0, 1, 0)
            if elapsed >= duration then
                conn:Disconnect()
                doClose()
            end
        end)
        _globalCleanup:Add(conn)
    end

    -- Public API — attached to RoundedUI below
    function NotifSystem.Notify(cfg)
        -- Short syntax: Notify("message")
        if type(cfg) == "string" then
            cfg = { Title = cfg, Type = "Info" }
        end
        NotifSystem._show(cfg)
    end
end

