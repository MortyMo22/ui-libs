		Name = "RoundedUI",
		ResetOnSpawn = false,
		IgnoreGuiInset = true,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	}, {})

	local CoreGui = game:GetService("CoreGui")
	gui.DisplayOrder = 2147483647
	gui.Parent = CoreGui

	local window = create("Frame", {
		Name = "Window",
		Size = UDim2.new(isMobile() and 0.95 or 0.6, 0, isMobile() and 0.8 or 0.7, 0),
		Position = UDim2.new(0.5, 0, 0.5, 0),
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = Theme.bg,
	}, {})
	window.Parent = gui
	addCorner(window, 12)
	addStroke(window, Theme.stroke, 1, 0.6)
	addPadding(window, 10)

	local header = create("Frame", {
		Name = "Header",
		Size = UDim2.new(1, 0, 0, 32),
		BackgroundColor3 = Theme.panel,
	}, {})
	header.Parent = window
	addCorner(header, 10)
	addStroke(header, Theme.stroke, 1, 0.6)

	local leftTitle = create("TextLabel", {
		Size = UDim2.new(0.5, -8, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		BackgroundTransparency = 1,
		Text = nameLeft or "UI",
		TextColor3 = Theme.text,
		Font = FONT_B,
		TextSize = 16,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, {})
	leftTitle.Parent = header

	local rightTitle = create("TextLabel", {
		Size = UDim2.new(1, -120, 1, 0),
		Position = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 1,
		Text = nameRight or "",
		TextColor3 = Theme.textDim,
		Font = FONT,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Right,
	}, {})
	rightTitle.Parent = header

	local closeBtn = create("TextButton", {
		Size = UDim2.new(0, 24, 0, 24),
		Position = UDim2.new(1, -28, 0.5, -12),
		BackgroundColor3 = Theme.warn,
		Text = "X",
		TextColor3 = Color3.new(1, 1, 1),
		Font = FONT_B,
		TextSize = 14,
	}, {})
	addCorner(closeBtn, 6)
	closeBtn.Parent = header

	local minimizeBtn = create("TextButton", {
		Size = UDim2.new(0, 24, 0, 24),
		Position = UDim2.new(1, -56, 0.5, -12),
		BackgroundColor3 = Theme.control,
		Text = "_",
		TextColor3 = Theme.text,
		Font = FONT_B,
		TextSize = 14,
	}, {})
	addCorner(minimizeBtn, 6)
	minimizeBtn.Parent = header

	do
		local dragging = false
		local dragStart
		local startPos

		header.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true
				dragStart = input.Position
				startPos = window.Position
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local delta = input.Position - dragStart
				window.Position = UDim2.new(
					startPos.X.Scale, startPos.X.Offset + delta.X,
					startPos.Y.Scale, startPos.Y.Offset + delta.Y
				)
			end
		end)

		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false
			end
		end)
	end

	local tabsStrip = create("ScrollingFrame", {
		Name = "Tabs",
		Size = UDim2.new(1, 0, 0, 44),
		Position = UDim2.new(0, 0, 0, 40),
		BackgroundColor3 = Theme.panel2,
		ScrollBarThickness = 4,
		ScrollingDirection = Enum.ScrollingDirection.X,
		CanvasSize = UDim2.new(0, 0, 0, 0),
	}, {})
	tabsStrip.Parent = window
	addCorner(tabsStrip, 10)
	addStroke(tabsStrip, Theme.stroke, 1, 0.5)
	addPadding(tabsStrip, 6)

	local tabsLayout = Instance.new("UIListLayout")
	tabsLayout.FillDirection = Enum.FillDirection.Horizontal
	tabsLayout.Padding = UDim.new(0, 6)
	tabsLayout.Parent = tabsStrip

	local content = create("Frame", {
		Name = "Content",
		Size = UDim2.new(1, 0, 1, -80),
		Position = UDim2.new(0, 0, 0, 80),
		BackgroundColor3 = Theme.bg,
	}, {})
	content.Parent = window
	addPadding(content, 6)

	local hidden = false
	local shownHint = false

	local function showHint()
		if shownHint then return end
		if isMobile() then return end
		shownHint = true
	end

	closeBtn.MouseButton1Click:Connect(function()
		gui:Destroy()
	end)

	minimizeBtn.MouseButton1Click:Connect(function()
		hidden = not hidden
		window.Visible = not hidden
		minimizeBtn.Text = hidden and "_+" or "_"
	end)

	local windowAPI = {
		_window = window,
		_gui = gui,
		_content = content,
		_tabs = {},
		_currentTab = nil,
	}

	function windowAPI:AddSection(sectionName)
		local section = create("Frame", {
			Name = sectionName .. "_Section",
			Size = UDim2.new(1, 0, 1, 0),
			BackgroundColor3 = Theme.panel,
			BorderSizePixel = 0,
			Visible = false,
		}, {})
		section.Parent = content

		addCorner(section, 10)
		addStroke(section, Theme.stroke, 1, 0.5)
		addPadding(section, 8)

		local sectionLayout = Instance.new("UIListLayout")
		sectionLayout.FillDirection = Enum.FillDirection.Vertical
		sectionLayout.Padding = UDim.new(0, 6)
		sectionLayout.Parent = section

		local sectionContent = create("Frame", {
			Name = "Content",
			Size = UDim2.new(1, 0, 0, 0),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			AutomaticSize = Enum.AutomaticSize.Y,
		}, {})
		sectionContent.Parent = section

		local contentLayout = Instance.new("UIListLayout")
		contentLayout.FillDirection = Enum.FillDirection.Vertical
		contentLayout.Padding = UDim.new(0, 6)
		contentLayout.Parent = sectionContent

		local sectionAPI = {
			_frame = section,
			_content = sectionContent,
			_layout = contentLayout,
		}

		function sectionAPI:AddUnderSections(...)
			local titles = {...}
			local underContainer = create("Frame", {
				Name = "UnderSections",
				Size = UDim2.new(1, 0, 0, 0),
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				AutomaticSize = Enum.AutomaticSize.Y,
			}, {})
			underContainer.Parent = sectionContent

			local underLayout = Instance.new("UIListLayout")
			underLayout.FillDirection = Enum.FillDirection.Horizontal
			underLayout.Padding = UDim.new(0, 6)
			underLayout.Parent = underContainer

			local underSections = {}

			for _, title in ipairs(titles) do
				local underSection = create("Frame", {
					Name = title .. "_UnderSection",
					Size = UDim2.new(1, 0, 0, 0),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					AutomaticSize = Enum.AutomaticSize.Y,
				}, {})
				underSection.Parent = underContainer

				local underSectionLayout = Instance.new("UIListLayout")
				underSectionLayout.FillDirection = Enum.FillDirection.Vertical
				underSectionLayout.Padding = UDim.new(0, 4)
				underSectionLayout.Parent = underSection

				local underAPI = {
					_frame = underSection,
					_content = underSection,
					_layout = underSectionLayout,
				}

				-- Добавляем методы для элементов управления
				function underAPI:Label(text, props)
					props = props or {}
					local label = create("TextLabel", {
						Size = UDim2.new(1, 0, 0, 20),
						BackgroundTransparency = 1,
						Text = text,
						TextColor3 = props.color or Theme.text,
						Font = props.bold and FONT_B or FONT,
						TextSize = props.size or 14,
						TextWrapped = true,
					}, {})
					label.Parent = underSection
					return label
				end

				function underAPI:Button(text, callback)
					local btn = create("TextButton", {
						Size = UDim2.new(1, 0, 0, 32),
						BackgroundColor3 = Theme.accent,
						Text = text,
						TextColor3 = Theme.text,
						Font = FONT_B,
						TextSize = 14,
					}, {})
					btn.Parent = underSection
					addCorner(btn, 6)
					withHover(btn, Theme.accent, Theme.accentDim)
					btn.MouseButton1Click:Connect(callback)
					return btn
				end

				function underAPI:Toggle(text, default, callback)
					local toggleContainer = create("Frame", {
						Size = UDim2.new(1, 0, 0, 32),
						BackgroundTransparency = 1,
						BorderSizePixel = 0,
					}, {})
					toggleContainer.Parent = underSection

					local toggleLabel = create("TextLabel", {
						Size = UDim2.new(1, -40, 1, 0),
						BackgroundTransparency = 1,
						Text = text,
						TextColor3 = Theme.text,
						Font = FONT,
						TextSize = 14,
						TextXAlignment = Enum.TextXAlignment.Left,
					}, {})
					toggleLabel.Parent = toggleContainer

					local toggle = create("TextButton", {
						Size = UDim2.new(0, 32, 1, 0),
						Position = UDim2.new(1, -32, 0, 0),
						BackgroundColor3 = default and Theme.good or Theme.control,
						Text = default and "On" or "Off",
						TextColor3 = Theme.text,
						Font = FONT_B,
						TextSize = 12,
					}, {})
					toggle.Parent = toggleContainer
					addCorner(toggle, 6)

					local state = default or false

					toggle.MouseButton1Click:Connect(function()
						state = not state
						toggle.BackgroundColor3 = state and Theme.good or Theme.control
						toggle.Text = state and "On" or "Off"
						if callback then callback(state) end
					end)

					return toggle
				end

				function underAPI:Slider(text, min, max, default, callback)
					local sliderContainer = create("Frame", {
						Size = UDim2.new(1, 0, 0, 50),
						BackgroundTransparency = 1,
						BorderSizePixel = 0,
					}, {})
					sliderContainer.Parent = underSection

					local sliderLabel = create("TextLabel", {
						Size = UDim2.new(1, 0, 0, 16),
						BackgroundTransparency = 1,
						Text = text .. ": " .. tostring(default or min),
						TextColor3 = Theme.text,
						Font = FONT,
						TextSize = 12,
					}, {})
					sliderLabel.Parent = sliderContainer

					local sliderBg = create("Frame", {
						Size = UDim2.new(1, 0, 0, 6),
						Position = UDim2.new(0, 0, 0, 20),
						BackgroundColor3 = Theme.control,
						BorderSizePixel = 0,
					}, {})
					sliderBg.Parent = sliderContainer
					addCorner(sliderBg, 3)

					local sliderFill = create("Frame", {
						Size = UDim2.new(0.5, 0, 1, 0),
						BackgroundColor3 = Theme.accent,
						BorderSizePixel = 0,
					}, {})
					sliderFill.Parent = sliderBg
					addCorner(sliderFill, 3)

					local sliderBtn = create("TextButton", {
						Size = UDim2.new(0, 12, 0, 12),
						Position = UDim2.new(0.5, -6, 0.5, -6),
						BackgroundColor3 = Theme.accent,
						Text = "",
						BorderSizePixel = 0,
					}, {})
					sliderBtn.Parent = sliderBg
					addCorner(sliderBtn, 6)

					local currentValue = default or min
					local dragging = false

					sliderBtn.InputBegan:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = true
						end
					end)

					UIS.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 then
							dragging = false
						end
					end)

					UIS.InputChanged:Connect(function(input)
						if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
							local relX = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
							currentValue = min + (max - min) * relX
							sliderFill.Size = UDim2.new(relX, 0, 1, 0)
							sliderLabel.Text = text .. ": " .. tostring(math.floor(currentValue))
							if callback then callback(currentValue) end
						end
					end)

					return sliderBg
				end

				-- Добавляем методы из extended components
				extendSectionWithNewComponents(underAPI)

				table.insert(underSections, underAPI)
			end

			return unpack(underSections)
		end

		-- Добавляем методы из extended components к main section
		extendSectionWithNewComponents(sectionAPI)

		table.insert(windowAPI._tabs, sectionAPI)

		if not windowAPI._currentTab then
			windowAPI._currentTab = sectionAPI
			sectionAPI._frame.Visible = true
		end

		return sectionAPI
	end

	return windowAPI
end

return RoundedUI
