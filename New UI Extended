-- 6. VirtualList - Виртуализированный список для больших данных
-- ============================================================================

local function createVirtualList(parentFrame, options)
	options = options or {}
	local height = options.Height or 260
	local itemHeight = options.ItemHeight or 60

	-- Контейнер
	local vlistContainer = create("Frame", {
		Name = "VirtualListContainer",
		Size = UDim2.new(1, 0, 0, height),
		BackgroundColor3 = Theme.panel2,
		BorderSizePixel = 0,
	}, {})
	vlistContainer.Parent = parentFrame
	addCorner(vlistContainer, 8)
	addStroke(vlistContainer, Theme.stroke, 1, 0.4)

	-- ScrollingFrame
	local scrollFrame = create("ScrollingFrame", {
		Name = "VirtualListScroll",
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 6,
		CanvasSize = UDim2.new(1, 0, 0, 0),
	}, {})
	scrollFrame.Parent = vlistContainer

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Vertical
	layout.Padding = UDim.new(0, 4)
	layout.Parent = scrollFrame

	addPadding(scrollFrame, 4)

	-- API
	local vlistAPI = {
		_frame = scrollFrame,
		_container = vlistContainer,
		_layout = layout,
		_items = {},
		_data = {},
		_renderer = nil,
		_itemHeight = itemHeight,
	}

	-- Метод: установить данные и отрисовать
	function vlistAPI:SetItems(dataArray)
		self._data = dataArray or {}
		self:_render()
	end

	-- Метод: установить функцию рендеринга
	function vlistAPI:SetRenderer(rendererFn)
		self._renderer = rendererFn
		self:_render()
	end

	-- Метод: добавить Card (удобство)
	function vlistAPI:Card()
		return createCard(scrollFrame)
	end

	-- Внутренний метод: отрисовка элементов
	function vlistAPI:_render()
		-- Очистить старые элементы
		for _, item in ipairs(self._items) do
			item:Destroy()
		end
		self._items = {}

		-- Отрисовать новые элементы
		if self._renderer then
			for i, itemData in ipairs(self._data) do
				local itemFrame = self._renderer(itemData, i)
				if itemFrame then
					itemFrame.Parent = scrollFrame
					table.insert(self._items, itemFrame)
				end
			end
		end

		-- Обновить размер канваса
		local totalHeight = #self._items * self._itemHeight + (4 * (#self._items - 1)) + (4 * 2)
		scrollFrame.CanvasSize = UDim2.new(1, 0, 0, totalHeight)
	end

	-- Метод: очистить список
	function vlistAPI:Clear()
		for _, item in ipairs(self._items) do
			item:Destroy()
		end
		self._items = {}
		self._data = {}
		scrollFrame.CanvasSize = UDim2.new(1, 0, 0, 0)
	end

	-- Метод: получить Frame
	function vlistAPI:GetFrame()
		return self._frame
	end

	return vlistAPI
end

-- ============================================================================
-- EXTENSIONS TO SECTION - Добавляем методы к Section
-- ============================================================================

local function extendSectionWithNewComponents(sectionObj)
	-- Метод: создать ScrollList
	function sectionObj:ScrollList(title, options)
		return createScrollList(sectionObj._content, title, options)
	end

	-- Метод: создать Card
	function sectionObj:Card()
		return createCard(sectionObj._content)
	end

	-- Метод: создать Container
	function sectionObj:Container(options)
		return createContainer(sectionObj._content, options)
	end

	-- Метод: создать SearchBox
	function sectionObj:SearchBox(placeholder, callback, options)
		return createSearchBox(sectionObj._content, placeholder, callback, options)
	end

	-- Метод: создать Pagination
	function sectionObj:Pagination(options)
		return createPagination(sectionObj._content, options)
	end

	-- Метод: создать VirtualList
	function sectionObj:VirtualList(options)
		return createVirtualList(sectionObj._content, options)
	end

	-- Метод: сделать Section скроллируемым
	function sectionObj:SetScrollable(isScrollable, scrollOptions)
		if not isScrollable then return end
		
		scrollOptions = scrollOptions or {}
		local maxHeight = scrollOptions.MaxHeight

		-- Если уже есть ScrollingFrame, не создаём новый
		if sectionObj._content:IsA("ScrollingFrame") then
			return
		end

		-- Получить текущих детей
		local children = {}
		for _, child in ipairs(sectionObj._content:GetChildren()) do
			table.insert(children, child)
		end

		-- Создать новый ScrollingFrame
		local newScroll = create("ScrollingFrame", {
			Name = "SectionScroll",
			Size = maxHeight and UDim2.new(1, 0, 0, maxHeight) or UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ScrollBarThickness = 6,
			CanvasSize = UDim2.new(1, 0, 2, 0),
		}, children)
		newScroll.Parent = sectionObj._content.Parent
		newScroll.Position = sectionObj._content.Position
		newScroll.LayoutOrder = sectionObj._content.LayoutOrder

		-- Заменить ссылку на content
		sectionObj._content:Destroy()
		sectionObj._content = newScroll

		-- Добавить layout
		local layout = Instance.new("UIListLayout")
		layout.FillDirection = Enum.FillDirection.Vertical
		layout.Padding = UDim.new(0, 6)
		layout.Parent = newScroll
	end

	return sectionObj
end

