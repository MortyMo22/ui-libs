-- ============================================================================
-- 1. ScrollList - Скроллируемый список с автоматическим расчётом высоты
-- ============================================================================

local function createScrollList(parentFrame, title, options)
	options = options or {}
	local height = options.Height
	local maxHeight = options.MaxHeight
	local padding = options.Padding or 6

	-- Контейнер для списка
	local listContainer = create("Frame", {
		Name = "ScrollListContainer",
		Size = height and UDim2.new(1, 0, 0, height) or UDim2.new(1, 0, 1, 0),
		BackgroundColor3 = Theme.panel2,
		BorderSizePixel = 0,
	}, {})
	listContainer.Parent = parentFrame
	addCorner(listContainer, 8)
	addStroke(listContainer, Theme.stroke, 1, 0.4)

	-- ScrollingFrame внутри
	local scrollFrame = create("ScrollingFrame", {
		Name = "ScrollList",
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 6,
		CanvasSize = UDim2.new(1, 0, 0, 0), -- будет пересчитана
	}, {})
	scrollFrame.Parent = listContainer

	-- UIListLayout для вертикального расположения
	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Vertical
	layout.Padding = UDim.new(0, padding)
	layout.Parent = scrollFrame

	addPadding(scrollFrame, padding)

	-- Объект API для управления списком
	local scrollListAPI = {
		_frame = scrollFrame,
		_container = listContainer,
		_layout = layout,
		_items = {},
	}

	-- Метод: добавить элемент в список
	function scrollListAPI:AddItem(frame)
		frame.Parent = scrollFrame
		table.insert(self._items, frame)
		self:_updateCanvasSize()
	end

	-- Метод: очистить список
	function scrollListAPI:Clear()
		for _, item in ipairs(self._items) do
			item:Destroy()
		end
		self._items = {}
		self:_updateCanvasSize()
	end

	-- Метод: изменить отступ между элементами
	function scrollListAPI:SetPadding(px)
		self._layout.Padding = UDim.new(0, px)
		self:_updateCanvasSize()
	end

	-- Метод: установить высоту списка
	function scrollListAPI:SetHeight(px)
		self._container.Size = UDim2.new(1, 0, 0, px)
		self:_updateCanvasSize()
	end

	-- Метод: установить максимальную высоту
	function scrollListAPI:SetMaxHeight(px)
		if px then
			self._container.Size = UDim2.new(1, 0, 0, math.min(px, self:_calculateNeededHeight()))
		end
		self:_updateCanvasSize()
	end

	-- Метод: получить ScrollingFrame
	function scrollListAPI:GetFrame()
		return self._frame
	end

	-- Внутренний метод: пересчёт размера канваса
	function scrollListAPI:_updateCanvasSize()
		local totalHeight = 0
		for _, item in ipairs(self._items) do
			totalHeight = totalHeight + item.AbsoluteSize.Y
		end
		totalHeight = totalHeight + (padding * (#self._items - 1)) + (padding * 2)
		self._frame.CanvasSize = UDim2.new(1, 0, 0, totalHeight)
	end

	-- Внутренний метод: вычислить нужную высоту
	function scrollListAPI:_calculateNeededHeight()
		local totalHeight = 0
		for _, item in ipairs(self._items) do
			totalHeight = totalHeight + item.AbsoluteSize.Y
		end
		return totalHeight + (padding * math.max(0, #self._items - 1)) + (padding * 2)
	end

	-- Обновить размер канваса при изменении размера элементов
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scrollListAPI:_updateCanvasSize()
	end)

	return scrollListAPI
end

-- ============================================================================
-- 2. Card - Карточка с методами для добавления содержимого
-- ============================================================================

local function createCard(parentFrame)
	-- Сама карточка
	local cardFrame = create("Frame", {
		Name = "Card",
		Size = UDim2.new(1, 0, 0, 0), -- будет подстраиваться
		BackgroundColor3 = Theme.panel2,
		BorderSizePixel = 0,
		AutomaticSize = Enum.AutomaticSize.Y,
	}, {})
	cardFrame.Parent = parentFrame
	addCorner(cardFrame, 8)
	addStroke(cardFrame, Theme.stroke, 1, 0.4)
	addPadding(cardFrame, 8)

	-- UIListLayout для вертикального расположения элементов в карточке
	local cardLayout = Instance.new("UIListLayout")
	cardLayout.FillDirection = Enum.FillDirection.Vertical
	cardLayout.Padding = UDim.new(0, 6)
	cardLayout.Parent = cardFrame

	-- Объект API для управления карточкой
	local cardAPI = {
		_frame = cardFrame,
		_layout = cardLayout,
	}

	-- Метод: добавить Label в карточку
	function cardAPI:Label(text, props)
		props = props or {}
		local bold = props.bold or false
		local size = props.size or 14
		local color = props.color or Theme.text
		local align = props.align or Enum.TextXAlignment.Left

		local label = create("TextLabel", {
			Size = UDim2.new(1, 0, 0, 20),
			BackgroundTransparency = 1,
			Text = text,
			TextColor3 = color,
			Font = bold and FONT_B or FONT,
			TextSize = size,
			TextXAlignment = align,
			TextWrapped = true,
		}, {})
		label.Parent = cardFrame

		return label
	end

	-- Метод: добавить Button в карточку
	function cardAPI:Button(text, callback, props)
		props = props or {}
		local size = props.size or 14

		local btn = create("TextButton", {
			Size = UDim2.new(1, 0, 0, 36),
			BackgroundColor3 = Theme.accent,
			Text = text,
			TextColor3 = Theme.text,
			Font = FONT_B,
			TextSize = size,
		}, {})
		btn.Parent = cardFrame
		addCorner(btn, 6)
		withHover(btn, Theme.accent, Theme.accentDim)

		btn.MouseButton1Click:Connect(callback)

		return btn
	end

	-- Метод: добавить Row (горизонтальный контейнер)
	function cardAPI:Row(rowProps)
		rowProps = rowProps or {}
		local rowAlign = rowProps.Align or "Left"
		local rowSpacing = rowProps.Spacing or 8

		local rowFrame = create("Frame", {
			Size = UDim2.new(1, 0, 0, 0),
			BackgroundTransparency = 1,
			AutomaticSize = Enum.AutomaticSize.Y,
		}, {})
		rowFrame.Parent = cardFrame

		local rowLayout = Instance.new("UIListLayout")
		rowLayout.FillDirection = Enum.FillDirection.Horizontal
		rowLayout.Padding = UDim.new(0, rowSpacing)
		
		if rowAlign == "Center" then
			rowLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		elseif rowAlign == "Right" then
			rowLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
		else
			rowLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
		end
		
		rowLayout.VerticalAlignment = Enum.VerticalAlignment.Center
		rowLayout.Parent = rowFrame

		addPadding(rowFrame, 0)

		local rowAPI = {
			_frame = rowFrame,
			_layout = rowLayout,
		}

		-- Метод: добавить Label в Row
		function rowAPI:Label(text, labelProps)
			labelProps = labelProps or {}
			local bold = labelProps.bold or false
			local size = labelProps.size or 12
			local color = labelProps.color or Theme.text

			local label = create("TextLabel", {
				Size = UDim2.new(0, 0, 0, 20),
				BackgroundTransparency = 1,
				Text = text,
				TextColor3 = color,
				Font = bold and FONT_B or FONT,
				TextSize = size,
				TextScaled = false,
				AutomaticSize = Enum.AutomaticSize.XY,
			}, {})
			label.Parent = rowFrame

			return label
		end

		-- Метод: добавить Button в Row
		function rowAPI:Button(text, btnCallback, btnProps)
			btnProps = btnProps or {}
			local size = btnProps.size or 12

			local btn = create("TextButton", {
				Size = UDim2.new(0, 80, 0, 28),
				BackgroundColor3 = Theme.accent,
				Text = text,
				TextColor3 = Theme.text,
				Font = FONT_B,
				TextSize = size,
			}, {})
			btn.Parent = rowFrame
			addCorner(btn, 6)
			withHover(btn, Theme.accent, Theme.accentDim)

			btn.MouseButton1Click:Connect(btnCallback)

			return btn
		end

		-- Метод: добавить кастомный объект в Row
		function rowAPI:AddCustom(instance)
			instance.Parent = rowFrame
			return instance
		end

		-- Метод: получить сам Frame
		function rowAPI:GetFrame()
			return self._frame
		end

		return rowAPI
	end

	-- Метод: получить сам Frame карточки
	function cardAPI:GetFrame()
		return self._frame
	end

	return cardAPI
end

-- ============================================================================
-- 3. Container / MountCustom - Контейнер для кастомного UI
-- ============================================================================

local function createContainer(parentFrame, options)
	options = options or {}
	local height = options.Height
	local scrollable = options.Scrollable or false

	if scrollable then
		-- Создаём ScrollingFrame
		local container = create("ScrollingFrame", {
			Name = "CustomContainer",
			Size = height and UDim2.new(1, 0, 0, height) or UDim2.new(1, 0, 1, 0),
			BackgroundColor3 = Theme.panel2,
			BorderSizePixel = 0,
			ScrollBarThickness = 6,
			CanvasSize = UDim2.new(1, 0, 2, 0),
		}, {})
		container.Parent = parentFrame
		addCorner(container, 8)
		addStroke(container, Theme.stroke, 1, 0.4)
		addPadding(container, 6)

		local containerAPI = {
			_frame = container,
		}

		function containerAPI:Mount(instance)
			instance.Parent = container
		end

		function containerAPI:GetFrame()
			return self._frame
		end

		return containerAPI
	else
		-- Создаём обычный Frame
		local container = create("Frame", {
			Name = "CustomContainer",
			Size = height and UDim2.new(1, 0, 0, height) or UDim2.new(1, 0, 1, 0),
			BackgroundColor3 = Theme.panel2,
			BorderSizePixel = 0,
		}, {})
		container.Parent = parentFrame
		addCorner(container, 8)
		addStroke(container, Theme.stroke, 1, 0.4)
		addPadding(container, 6)

		local containerAPI = {
			_frame = container,
		}

		function containerAPI:Mount(instance)
			instance.Parent = container
		end

		function containerAPI:GetFrame()
			return self._frame
		end

		return containerAPI
	end
end

