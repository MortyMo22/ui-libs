-- 5. Pagination - Компонент для управления страницами
-- ============================================================================

local function createPagination(parentFrame, options)
	options = options or {}
	local align = options.Align or "Center"

	-- Контейнер для пагинации
	local pagerContainer = create("Frame", {
		Name = "PaginationContainer",
		Size = UDim2.new(1, 0, 0, 40),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
	}, {})
	pagerContainer.Parent = parentFrame

	local pagerLayout = Instance.new("UIListLayout")
	pagerLayout.FillDirection = Enum.FillDirection.Horizontal
	pagerLayout.Padding = UDim.new(0, 8)
	
	if align == "Center" then
		pagerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	elseif align == "Right" then
		pagerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
	else
		pagerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	end
	
	pagerLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	pagerLayout.Parent = pagerContainer

	-- Кнопка Prev
	local prevBtn = create("TextButton", {
		Size = UDim2.new(0, 80, 1, 0),
		BackgroundColor3 = Theme.control,
		Text = "◄ Prev",
		TextColor3 = Theme.text,
		Font = FONT_B,
		TextSize = 14,
	}, {})
	prevBtn.Parent = pagerContainer
	addCorner(prevBtn, 6)
	withHover(prevBtn, Theme.control, Theme.hover)

	-- Label с текущей страницей
	local pageLabel = create("TextLabel", {
		Size = UDim2.new(0, 100, 1, 0),
		BackgroundTransparency = 1,
		Text = "Page 1",
		TextColor3 = Theme.text,
		Font = FONT,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Center,
	}, {})
	pageLabel.Parent = pagerContainer

	-- Кнопка Next
	local nextBtn = create("TextButton", {
		Size = UDim2.new(0, 80, 1, 0),
		BackgroundColor3 = Theme.control,
		Text = "Next ►",
		TextColor3 = Theme.text,
		Font = FONT_B,
		TextSize = 14,
	}, {})
	nextBtn.Parent = pagerContainer
	addCorner(nextBtn, 6)
	withHover(nextBtn, Theme.control, Theme.hover)

	-- API для управления пагинацией
	local pagerAPI = {
		_prevBtn = prevBtn,
		_nextBtn = nextBtn,
		_pageLabel = pageLabel,
		_currentPage = 1,
		_hasNext = false,
		_hasPrev = false,
		OnNext = nil,
		OnPrev = nil,
	}

	-- Метод: установить текущую страницу
	function pagerAPI:SetPage(page)
		self._currentPage = page
		self._pageLabel.Text = "Page " .. tostring(page)
	end

	-- Метод: указать, есть ли следующая страница
	function pagerAPI:SetHasNext(has)
		self._hasNext = has
		self._nextBtn.TextTransparency = has and 0 or 0.5
		self._nextBtn.Active = has
	end

	-- Метод: указать, есть ли предыдущая страница
	function pagerAPI:SetHasPrev(has)
		self._hasPrev = has
		self._prevBtn.TextTransparency = has and 0 or 0.5
		self._prevBtn.Active = has
	end

	-- Метод: включить/отключить пагинацию
	function pagerAPI:SetEnabled(enabled)
		self._nextBtn.Active = enabled
		self._prevBtn.Active = enabled
	end

	-- Подключаем кнопки
	nextBtn.MouseButton1Click:Connect(function()
		if pagerAPI._hasNext and pagerAPI.OnNext then
			pagerAPI.OnNext()
		end
	end)

	prevBtn.MouseButton1Click:Connect(function()
		if pagerAPI._hasPrev and pagerAPI.OnPrev then
			pagerAPI.OnPrev()
		end
	end)

	return pagerAPI
end

