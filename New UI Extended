-- 4. SearchBox - Поле поиска с иконкой и стилем
-- ============================================================================

local function createSearchBox(parentFrame, placeholder, callback, options)
	options = options or {}
	local placeholderColor = options.PlaceholderColor or Theme.textDim
	local textColor = options.TextColor or Theme.text

	-- Контейнер для SearchBox
	local searchContainer = create("Frame", {
		Name = "SearchBoxContainer",
		Size = UDim2.new(1, 0, 0, 40),
		BackgroundColor3 = Theme.control,
		BorderSizePixel = 0,
	}, {})
	searchContainer.Parent = parentFrame
	addCorner(searchContainer, 8)
	addStroke(searchContainer, Theme.stroke, 1, 0.4)

	-- Иконка поиска (текст 🔍)
	local iconLabel = create("TextLabel", {
		Size = UDim2.new(0, 40, 1, 0),
		BackgroundTransparency = 1,
		Text = "🔍",
		TextColor3 = Theme.textDim,
		Font = FONT,
		TextSize = 18,
		TextXAlignment = Enum.TextXAlignment.Center,
	}, {})
	iconLabel.Parent = searchContainer

	-- TextBox для ввода
	local textBox = create("TextBox", {
		Name = "SearchInput",
		Size = UDim2.new(1, -50, 1, 0),
		Position = UDim2.new(0, 40, 0, 0),
		BackgroundTransparency = 1,
		PlaceholderText = placeholder or "Search...",
		PlaceholderColor3 = placeholderColor,
		Text = "",
		TextColor3 = textColor,
		Font = FONT,
		TextSize = 14,
		TextXAlignment = Enum.TextXAlignment.Left,
		ClearTextOnFocus = false,
	}, {})
	textBox.Parent = searchContainer

	-- API для управления SearchBox
	local searchAPI = {
		_textBox = textBox,
		_container = searchContainer,
	}

	-- Метод: установить текст
	function searchAPI:SetText(text)
		self._textBox.Text = text
	end

	-- Метод: получить текст
	function searchAPI:GetText()
		return self._textBox.Text
	end

	-- Метод: установить callback
	function searchAPI:SetCallback(fn)
		if fn then
			self._textBox.FocusLost:Connect(fn)
		end
	end

	-- Подключаем callback при изменении текста (FocusLost)
	if callback then
		textBox.FocusLost:Connect(function(enterPressed)
			callback(textBox.Text)
		end)
	end

	return searchAPI
end

